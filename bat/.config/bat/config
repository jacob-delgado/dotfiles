# bat config — invoked once per `bat` run.
# Each line is a flag passed to `bat`, exactly as you'd type it on the CLI.

# Theme: ansi respects the terminal palette (which is themed by p10k /
# Dracula). Run `bat --list-themes` for alternatives.
--theme="ansi"

# Denser info: line numbers, git change markers, file header (name + size),
# grid separator between gutter and content.
--style="numbers,changes,header,grid,header-filesize"

# Pager: less with raw colors, quit-if-one-screen, no alt-screen.
# Matches the LESS env in zsh/.zshrc.
--pager="less -RFX"

# Teach bat about filenames it doesn't recognize by default.
--map-syntax="Dockerfile.*:Dockerfile"
--map-syntax="*.jenkinsfile:Groovy"
--map-syntax="*.tfvars:HCL"
--map-syntax=".envrc:Bash"
--map-syntax=".ignore:Git Ignore"
