# Global editorconfig — used by editorconfig-aware editors when a repo
# doesn't supply its own. Per-project .editorconfig wins.
# Spec: https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# Languages where tabs are the convention.
[*.go]
indent_style = tab

[{Makefile,*.mk}]
indent_style = tab

[*.py]
indent_size = 4

[*.{rs,c,cpp,h,hpp,java,kt,scala}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false   # two trailing spaces = line break in Markdown
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2
