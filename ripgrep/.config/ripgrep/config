# ripgrep config — read when RIPGREP_CONFIG_PATH points here.
# One flag per line; same syntax as the CLI.

# Case-insensitive search unless the query has uppercase letters.
--smart-case

# Search hidden files (still respects .gitignore unless --no-ignore).
--hidden

# Cap matched-line width — keeps minified JS / base64 blobs / long single-line
# JSON from blowing out the terminal. The preview flag shows a truncation
# message instead of just hiding the line.
--max-columns=200
--max-columns-preview

# Always-exclude paths regardless of project's .gitignore.
--glob=!.git/*
--glob=!node_modules/*
--glob=!.venv/*
--glob=!__pycache__/*
--glob=!dist/*
--glob=!build/*
--glob=!target/*
--glob=!vendor/*
--glob=!*.min.js
--glob=!*.min.css
--glob=!*.map

# Custom filetype aliases — usage: rg --type tf "module"
--type-add=tf:*.{tf,tfvars}
--type-add=k8s:*.{yaml,yml}
--type-add=helm:*.{yaml,yml,tpl}
--type-add=proto:*.proto

# Dracula theme — https://draculatheme.com/ripgrep
# path = purple, line/column = green, match = red.
--colors=path:fg:0xbd,0x93,0xf9
--colors=line:fg:0x50,0xfa,0x7b
--colors=column:fg:0x50,0xfa,0x7b
--colors=match:fg:0xff,0x55,0x55
