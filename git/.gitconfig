[user]
	name = Jacob Delgado
	email = jacobdelgado@gmail.com

# INCLUDES
# --------
# Local/Private config goes in the include
[include]
  path = ~/.gitconfig.local
# URL ALIASES
# -----------
# Alias for Dracula Org repositories
[url "https://github.com/dracula/"]
  insteadOf = dracula://
# COLORS
# ------
# Dracula Dark Theme
[color]
  ui = auto
[color "branch"]
  current = cyan bold reverse
  local = white
  plain =
  remote = cyan
[color "diff"]
  commit =
  func = cyan
  plain =
  whitespace = magenta reverse
  meta = white
  frag = cyan bold reverse
  old = red
  new = green
[color "grep"]
  context =
  filename =
  function =
  linenumber = white
  match =
  selected =
  separator =
[color "interactive"]
  error =
  header =
  help =
  prompt =
[color "status"]
  added = green
  changed = yellow
  header =
  localBranch =
  nobranch =
  remoteBranch = cyan bold
  unmerged = magenta bold reverse
  untracked = red
  updated = green bold
[core]
  pager = delta
  excludesfile = ~/.gitignore_global
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true        # use n / N to jump between hunks
  side-by-side = true    # split view; drop this for a single-column unified diff
  line-numbers = true
[merge]
  conflictstyle = zdiff3 # better 3-way conflict markers; needs git ≥ 2.35

# BEHAVIOR
# --------
[init]
  defaultBranch = main
[pull]
  rebase = true        # rebase on pull rather than merge
  ff = only            # error on diverged history; force explicit rebase/merge
[push]
  default = current
  autoSetupRemote = true   # `git push` on a new branch sets upstream (git ≥ 2.37)
  followTags = true
[fetch]
  prune = true         # remove local refs whose remote branch is gone
[rebase]
  autosquash = true    # auto-apply `fixup!` commits
  autoStash = true     # stash uncommitted work during rebase, restore after
[diff]
  algorithm = histogram   # better refactor diffs
  colorMoved = default    # highlight moved blocks
  renames = copies        # detect copies too, not just renames
[rerere]
  enabled = true       # remember conflict resolutions, replay on re-rebase

# ALIASES
# -------
[alias]
  st = status -sb
  co = checkout
  br = branch
  cm = commit
  ca = commit --amend
  cane = commit --amend --no-edit
  lg = log --graph --pretty=format:'%C(yellow)%h%Creset %C(cyan)%an%Creset %s %C(green)(%ar)%Creset%C(red)%d%Creset' --abbrev-commit
  last = log -1 HEAD --stat
  staged = diff --cached
  unstage = reset HEAD --
  undo = reset --soft HEAD^
  wip = !git add -A && git commit -m 'WIP'
  prune-branches = !git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n1 git branch -d
